---
export interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = false } = Astro.props;
---

<div
  class={`relative rounded-[2rem] p-[1.5px] ${hover ? 'transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:scale-[1.01]' : ''} ${className}`}
  style="background: linear-gradient(135deg, rgba(96,165,250,0.12) 0%, rgba(244,114,182,0.06) 100%)"
>
  <div class="rounded-[calc(2rem-1.5px)] bg-bg-card/90 p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.06)] backdrop-blur-xl">
    <slot />
  </div>
</div>
