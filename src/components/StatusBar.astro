---
import { siteConfig } from '../site.config';

export interface Props {
  postCount: number;
  lastUpdate: Date | null;
}

const { postCount, lastUpdate } = Astro.props;
const launchMs = new Date(siteConfig.launchDate).getTime();
const navItems = [
  { label: '首页', href: '/' },
  { label: '博客', href: '/blog' },
  { label: '关于', href: '/about' },
  { label: '联系', href: '/contact' },
];
---

<header
  id="status-bar"
  class="fixed left-0 top-0 z-50 w-full border-b border-black/5 bg-white/80 backdrop-blur-xl"
>
  <div class="mx-auto flex h-10 max-w-[1400px] items-center justify-between px-4 text-[11px]">
    <!-- 左侧：状态信息 -->
    <div class="flex items-center gap-4 overflow-hidden text-text-body/50">
      <span class="flex items-center gap-1.5 shrink-0">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400 shadow-[0_0_4px_rgba(52,211,153,0.6)]"></span>
        <span>在线</span>
      </span>

      <span id="status-clock" class="shrink-0 tabular-nums text-text-body/70">--:--:--</span>

      <span id="status-weather" class="shrink-0 hidden sm:inline">--°C</span>

      {lastUpdate && (
        <span class="hidden shrink-0 md:inline">
          更新于 {lastUpdate.toLocaleDateString(siteConfig.locale, { month: 'short', day: 'numeric' })}
        </span>
      )}

      <span id="status-days" class="hidden shrink-0 lg:inline" data-launch={launchMs}>运行中</span>

      <span class="hidden shrink-0 sm:inline">{postCount} 篇文章</span>

      <span id="status-visitors" class="hidden shrink-0 lg:inline">访客</span>
    </div>

    <!-- 右侧：导航 + 搜索 -->
    <div class="flex items-center gap-1 shrink-0">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-md px-2.5 py-1 font-medium text-text-body/50 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-text-heading data-[current]:text-accent"
          data-current={Astro.url.pathname === item.href ? '' : undefined}
        >
          {item.label}
        </a>
      ))}
      <button
        id="status-search"
        class="ml-1 flex items-center gap-1 rounded-md px-2 py-1 text-text-body/40 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-accent"
        title="搜索 (开发中)"
      >
        <i class="ri-search-line text-sm"></i>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    // 运行天数
    var daysEl = document.getElementById('status-days');
    if (daysEl) {
      var launchMs = parseInt(daysEl.getAttribute('data-launch'), 10);
      var days = Math.floor((Date.now() - launchMs) / 86400000);
      daysEl.textContent = '已运行 ' + days + ' 天';
    }

    // 实时时钟
    function updateClock() {
      var el = document.getElementById('status-clock');
      if (el) {
        el.textContent = new Date().toLocaleTimeString('zh-CN', { hour12: false });
      }
    }
    updateClock();
    setInterval(updateClock, 1000);

    // 天气
    function getWeatherIcon(code) {
      if (code <= 1) return '☀️';
      if (code === 2) return '⛅';
      if (code === 3) return '☁️';
      if (code <= 48) return '🌫';
      if ([51,53,55,56,57,61,63,65,66,67,80,81,82].indexOf(code) >= 0) return '🌧';
      if ([71,73,75,77,85,86].indexOf(code) >= 0) return '🌨';
      if ([95,96,99].indexOf(code) >= 0) return '⛈';
      return '🌤';
    }

    async function fetchWeather(lat, lon) {
      try {
        if (!lat) { lat = 30.57; lon = 104.07; }
        var res = await fetch(
          'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon + '&current=temperature_2m,weather_code&timezone=auto'
        );
        var data = await res.json();
        var temp = Math.round(data.current.temperature_2m);
        var icon = getWeatherIcon(data.current.weather_code);
        var el = document.getElementById('status-weather');
        if (el) el.textContent = icon + ' ' + temp + '°C';
      } catch(e) {}
    }

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(pos) { fetchWeather(pos.coords.latitude, pos.coords.longitude); },
        function() { fetchWeather(); },
        { timeout: 5000 }
      );
    } else {
      fetchWeather();
    }

    // 访客计数
    var visitorsEl = document.getElementById('status-visitors');
    if (visitorsEl) {
      var key = 'site_visits';
      var count = parseInt(localStorage.getItem(key) || '0', 10);
      var today = new Date().toDateString();
      if (localStorage.getItem('site_last_visit') !== today) {
        count++;
        localStorage.setItem(key, String(count));
        localStorage.setItem('site_last_visit', today);
      }
      visitorsEl.textContent = '访客 ' + count;
    }

    // 搜索按钮
    var searchBtn = document.getElementById('status-search');
    if (searchBtn) {
      searchBtn.addEventListener('click', function() {
        var q = prompt('输入搜索关键词：');
        if (q) {
          window.open('https://www.google.com/search?q=site:' + location.hostname + '+' + encodeURIComponent(q), '_blank');
        }
      });
    }

    // 导航高亮
    function updateNav() {
      var path = window.location.pathname;
      document.querySelectorAll('#status-bar a').forEach(function(a) {
        var href = a.getAttribute('href');
        if (href) {
          if (path === href || (href !== '/' && path.indexOf(href) === 0)) {
            a.setAttribute('data-current', '');
          } else {
            a.removeAttribute('data-current');
          }
        }
      });
    }
    updateNav();
    document.addEventListener('astro:after-swap', updateNav);
  })();
</script>
