---
import { siteConfig } from '../site.config';
---

<footer class="relative z-0 border-t border-white/5 py-16">
  <div class="container-page">
    <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
      <div class="flex items-center gap-6 text-sm text-white/30">
        <span>&copy; {new Date().getFullYear()} {siteConfig.author.name}. All rights reserved.</span>
      </div>
      <div class="flex items-center gap-8">
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="text-white/30 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-white/70">
          <i class="ri-github-fill text-xl"></i>
        </a>
        <a href={siteConfig.social.bilibili} target="_blank" rel="noopener noreferrer" class="text-white/30 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-white/70">
          <i class="ri-bilibili-fill text-xl"></i>
        </a>
        <a href="/rss.xml" class="text-white/30 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-white/70">
          <i class="ri-rss-fill text-xl"></i>
        </a>
      </div>
    </div>
  </div>
</footer>
