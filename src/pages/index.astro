---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../site.config';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="首页" description={siteConfig.description}>
  <section class="flex min-h-[100dvh] flex-col justify-center px-6 md:px-12">
    <div class="mx-auto w-full max-w-[1280px]">
      <ScrollReveal>
        <span class="inline-block rounded-full border border-particle-blue/15 bg-particle-blue/8 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-text-body/50">
          个人空间
        </span>
      </ScrollReveal>

      <ScrollReveal>
        <h1 class="mt-8 font-display text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl lg:text-8xl">
          Hi，我是 <span class="bg-gradient-to-r from-particle-blue via-accent to-accent-dark bg-clip-text text-transparent">{siteConfig.author.name}</span>
        </h1>
      </ScrollReveal>

      <ScrollReveal>
        <p class="mt-8 max-w-[600px] text-lg leading-relaxed text-text-body/80 md:text-xl">
          {siteConfig.author.bio}
        </p>
      </ScrollReveal>

      <ScrollReveal>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/blog"
            class="group inline-flex items-center gap-3 rounded-full border border-accent/30 bg-accent/15 px-6 py-3 text-sm font-medium text-accent transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-accent/25 hover:border-accent/50 active:scale-[0.98]"
          >
            阅读博客
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-accent/20 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105">
              <i class="ri-arrow-right-line text-xs"></i>
            </span>
          </a>
          <a
            href="/about"
            class="group inline-flex items-center gap-3 rounded-full border border-black/10 bg-transparent px-6 py-3 text-sm font-medium text-text-body/60 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:border-accent/30 hover:text-accent active:scale-[0.98]"
          >
            关于我
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-black/5 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:bg-accent/15 group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105">
              <i class="ri-user-line text-xs"></i>
            </span>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-32">
    <div class="container-page">
      <ScrollReveal>
        <span class="inline-block rounded-full border border-particle-blue/15 bg-particle-blue/8 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-text-body/50">
          作品
        </span>
        <h2 class="mt-4 font-display text-3xl font-semibold tracking-tight md:text-4xl text-text-heading">
          我的项目
        </h2>
      </ScrollReveal>

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {siteConfig.projects.map((project) => (
          <ScrollReveal>
            <a href={project.link} target="_blank" rel="noopener noreferrer" class="group block">
              <div class="relative rounded-[2rem] p-[1.5px] transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:scale-[1.01]"
                style="background: linear-gradient(135deg, rgba(96,165,250,0.2) 0%, rgba(236,72,153,0.1) 100%)">
                <div class="rounded-[calc(2rem-1.5px)] bg-white/80 p-8 shadow-sm backdrop-blur-xl">
                  <div class="mb-3 flex items-center gap-3">
                    {project.tech.slice(0, 3).map((t: string) => (
                      <span class="rounded-full border border-particle-blue/10 bg-particle-blue/5 px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-[0.15em] text-text-body/50">
                        {t}
                      </span>
                    ))}
                  </div>
                  <h3 class="font-display text-xl font-semibold tracking-tight text-text-heading group-hover:text-accent transition-colors duration-700">
                    {project.name}
                  </h3>
                  <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-text-body/70">
                    {project.description}
                  </p>
                  <div class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-text-body/50 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:text-accent">
                    查看项目
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-black/5 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105 group-hover:bg-accent/15">
                      <i class="ri-arrow-right-up-line text-xs"></i>
                    </span>
                  </div>
                </div>
              </div>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  {
    recentPosts.length > 0 && (
      <section class="py-32">
        <div class="container-page">
          <ScrollReveal>
            <div class="mb-16 flex items-center justify-between">
              <div>
                <span class="inline-block rounded-full border border-particle-blue/15 bg-particle-blue/8 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-text-body/50">
                  最新
                </span>
                <h2 class="mt-4 font-display text-3xl font-semibold tracking-tight md:text-4xl text-text-heading">
                  最近文章
                </h2>
              </div>
              <a
                href="/blog"
                class="hidden items-center gap-2 text-sm font-medium text-text-body/50 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-accent md:flex"
              >
                查看全部
                <i class="ri-arrow-right-line"></i>
              </a>
            </div>
          </ScrollReveal>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {recentPosts.map((post, i) => (
              <ScrollReveal>
                <a
                  href={`/blog/${post.slug}`}
                  class="group block"
                >
                  <div class="relative rounded-[2rem] p-[1.5px] transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:scale-[1.01]"
                    style="background: linear-gradient(135deg, rgba(96,165,250,0.2) 0%, rgba(236,72,153,0.1) 100%)">
                    <div class="rounded-[calc(2rem-1.5px)] bg-white/80 p-8 shadow-sm backdrop-blur-xl">
                      <div class="mb-3 flex items-center gap-3">
                        {post.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="rounded-full border border-particle-blue/10 bg-particle-blue/5 px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-[0.15em] text-text-body/50">
                            {tag}
                          </span>
                        ))}
                      </div>
                      <h3 class="font-display text-xl font-semibold tracking-tight text-text-heading group-hover:text-accent transition-colors duration-700">
                        {post.data.title}
                      </h3>
                      {post.data.description && (
                        <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-text-body/70">
                          {post.data.description}
                        </p>
                      )}
                      <time datetime={post.data.date.toISOString()} class="mt-4 block text-xs text-text-body/35">
                        {post.data.date.toLocaleDateString(siteConfig.locale, { year: 'numeric', month: 'long', day: 'numeric' })}
                      </time>
                      <div class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-text-body/50 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:text-accent">
                        阅读全文
                        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-black/5 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105 group-hover:bg-accent/15">
                          <i class="ri-arrow-right-up-line text-xs"></i>
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              </ScrollReveal>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
