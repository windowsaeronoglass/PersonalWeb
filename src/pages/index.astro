---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../site.config';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home" description={siteConfig.description}>
  <section class="flex min-h-[100dvh] flex-col justify-center px-6 md:px-12">
    <div class="mx-auto w-full max-w-[1280px]">
      <ScrollReveal>
        <span class="inline-block rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-white/50">
          Personal Space
        </span>
      </ScrollReveal>

      <ScrollReveal>
        <h1 class="mt-8 font-display text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl lg:text-8xl">
          Hi, I'm <span class="bg-gradient-to-r from-white via-white/80 to-white/50 bg-clip-text text-transparent">{siteConfig.author.name}</span>
        </h1>
      </ScrollReveal>

      <ScrollReveal>
        <p class="mt-8 max-w-[600px] text-lg leading-relaxed text-white/40 md:text-xl">
          {siteConfig.author.bio}
        </p>
      </ScrollReveal>

      <ScrollReveal>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/blog"
            class="group inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/[0.05] px-6 py-3 text-sm font-medium text-white transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-white/[0.1] active:scale-[0.98]"
          >
            Read the blog
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white/10 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105">
              <i class="ri-arrow-right-line text-xs"></i>
            </span>
          </a>
          <a
            href="/about"
            class="group inline-flex items-center gap-3 rounded-full border border-white/10 bg-transparent px-6 py-3 text-sm font-medium text-white/50 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:border-white/20 hover:text-white active:scale-[0.98]"
          >
            About me
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-white/5 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:bg-white/10 group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105">
              <i class="ri-user-line text-xs"></i>
            </span>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  {
    recentPosts.length > 0 && (
      <section class="py-32">
        <div class="container-page">
          <ScrollReveal>
            <div class="mb-16 flex items-center justify-between">
              <div>
                <span class="inline-block rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-white/50">
                  Latest
                </span>
                <h2 class="mt-4 font-display text-3xl font-semibold tracking-tight md:text-4xl">
                  Recent Posts
                </h2>
              </div>
              <a
                href="/blog"
                class="hidden items-center gap-2 text-sm font-medium text-white/40 transition-colors duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:text-white md:flex"
              >
                View all
                <i class="ri-arrow-right-line"></i>
              </a>
            </div>
          </ScrollReveal>

          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {recentPosts.map((post, i) => (
              <ScrollReveal>
                <a
                  href={`/blog/${post.slug}`}
                  class="group block"
                >
                  <div class="relative rounded-[2rem] p-[1.5px] transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] hover:scale-[1.01]"
                    style="background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%)">
                    <div class="rounded-[calc(2rem-1.5px)] bg-white/[0.03] p-8 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)] backdrop-blur-xl">
                      <div class="mb-3 flex items-center gap-3">
                        {post.data.tags.slice(0, 2).map((tag: string) => (
                          <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-[10px] font-medium uppercase tracking-[0.15em] text-white/40">
                            {tag}
                          </span>
                        ))}
                      </div>
                      <h3 class="font-display text-xl font-semibold tracking-tight text-white">
                        {post.data.title}
                      </h3>
                      {post.data.description && (
                        <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-white/40">
                          {post.data.description}
                        </p>
                      )}
                      <time datetime={post.data.date.toISOString()} class="mt-4 block text-xs text-white/25">
                        {post.data.date.toLocaleDateString(siteConfig.locale, { year: 'numeric', month: 'long', day: 'numeric' })}
                      </time>
                      <div class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-white/50">
                        Read more
                        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-white/5 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-1 group-hover:-translate-y-[1px] group-hover:scale-105">
                          <i class="ri-arrow-right-up-line text-xs"></i>
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              </ScrollReveal>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
