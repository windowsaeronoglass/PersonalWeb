---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import GlassCard from '../components/GlassCard.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout title="关于" description="关于我 — 我是谁，我做什么。">
  <section class="container-page py-32">
    <ScrollReveal>
      <span class="inline-block rounded-full border border-particle-blue/15 bg-particle-blue/8 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-text-body/50">
        关于
      </span>
      <h1 class="mt-4 font-display text-4xl font-semibold tracking-tight md:text-6xl">
        我是谁
      </h1>
    </ScrollReveal>

    <div class="mt-16 grid gap-12 lg:grid-cols-[1fr_1.5fr]">
      <ScrollReveal>
        <div class="relative overflow-hidden rounded-[2rem] p-[1.5px]"
          style="background: linear-gradient(135deg, rgba(96,165,250,0.2) 0%, rgba(236,72,153,0.1) 100%)">
          <div class="aspect-[3/4] rounded-[calc(2rem-1.5px)] bg-white/80 p-6 shadow-sm backdrop-blur-xl">
            <div class="flex h-full items-center justify-center text-text-body/10">
              <i class="ri-user-line text-8xl"></i>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <div class="space-y-8">
        <ScrollReveal>
          <GlassCard>
            <h2 class="font-display text-2xl font-semibold tracking-tight text-accent">你好</h2>
            <p class="mt-4 leading-relaxed text-text-body/80">
              {siteConfig.author.aboutText}
            </p>
          </GlassCard>
        </ScrollReveal>

        <ScrollReveal>
          <GlassCard>
            <h2 class="font-display text-2xl font-semibold tracking-tight text-particle-blue">技能</h2>
            <div class="mt-4 flex flex-wrap gap-2">
              {siteConfig.skills.map((skill) => (
                <span class="rounded-full border border-particle-blue/10 bg-particle-blue/5 px-3 py-1.5 text-xs font-medium text-text-body/70">
                  {skill}
                </span>
              ))}
            </div>
          </GlassCard>
        </ScrollReveal>

        <ScrollReveal>
          <GlassCard>
            <h2 class="font-display text-2xl font-semibold tracking-tight text-text-body">关于本站</h2>
            <p class="mt-4 leading-relaxed text-text-body/70">
              基于 <span class="text-particle-blue font-medium">Astro</span> 构建，使用
              <span class="text-accent font-medium">Tailwind CSS</span> 样式，部署在自有服务器上。
              设计采用毛玻璃风格与动态粒子背景。
            </p>
          </GlassCard>
        </ScrollReveal>
      </div>
    </div>
  </section>
</BaseLayout>
