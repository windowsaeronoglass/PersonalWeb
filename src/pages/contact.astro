---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ContactForm from '../components/ContactForm.astro';
import GlassCard from '../components/GlassCard.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout title="联系" description="与我取得联系。">
  <section class="container-page py-32">
    <ScrollReveal>
      <span class="inline-block rounded-full border border-particle-blue/15 bg-particle-blue/8 px-3 py-1 text-[10px] font-medium uppercase tracking-[0.2em] text-text-body/50">
        联系方式
      </span>
      <h1 class="mt-4 font-display text-4xl font-semibold tracking-tight md:text-6xl">
        联系我
      </h1>
      <p class="mt-4 max-w-[500px] text-text-body/70">
        有问题、项目想法，或者只是想打个招呼？填下表，我会尽快回复。
      </p>
    </ScrollReveal>

    <div class="mt-16 grid gap-12 lg:grid-cols-[1fr_1.5fr]">
      <div class="space-y-6">
        <ScrollReveal>
          <GlassCard>
            <a href={`mailto:${siteConfig.author.email}`} class="flex items-start gap-4 group">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/10 text-accent group-hover:bg-accent/20 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
                <i class="ri-mail-line"></i>
              </span>
              <div>
                <h3 class="font-semibold text-text-heading">邮箱</h3>
                <p class="mt-1 text-sm text-text-body/50 group-hover:text-accent transition-colors duration-700">{siteConfig.author.email}</p>
              </div>
            </a>
          </GlassCard>
        </ScrollReveal>

        <ScrollReveal>
          <GlassCard>
            <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 group">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-particle-blue/10 text-particle-blue group-hover:bg-particle-blue/20 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
                <i class="ri-github-fill"></i>
              </span>
              <div>
                <h3 class="font-semibold text-text-heading">GitHub</h3>
                <p class="mt-1 text-sm text-text-body/50 group-hover:text-particle-blue transition-colors duration-700">{siteConfig.social.github.replace('https://github.com/', '')}</p>
              </div>
            </a>
          </GlassCard>
        </ScrollReveal>

        <ScrollReveal>
          <GlassCard>
            <a href={siteConfig.social.bilibili} target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 group">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/10 text-accent group-hover:bg-accent/20 transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)]">
                <i class="ri-bilibili-fill"></i>
              </span>
              <div>
                <h3 class="font-semibold text-text-heading">Bilibili</h3>
                <p class="mt-1 text-sm text-text-body/50 group-hover:text-accent transition-colors duration-700">UID: 353979806</p>
              </div>
            </a>
          </GlassCard>
        </ScrollReveal>
      </div>

      <ScrollReveal>
        <ContactForm />
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
